def refresh_tasks():
    for widget in task_container.winfo_children():
        widget.destroy()

    for i, task in enumerate(tasks):

        task_frame = Frame(task_container, relief = "solid", bd = 1)
        task_frame.pack(fill = X, padx = 10, pady = 5)

        task["frame"] = task_frame

        delete_button = Button(
            task_frame,
            text = "❌",
            command = lambda t=task: delete_task(t)
        )

        task["delete_button"] = delete_button

        if delete_mode:
            delete_button.pack(side = RIGHT, padx = 5)

        done_var = BooleanVar(value = task["done"])

        def mark_done(t=task, var = done_var):
            t["done"] = var.get()
            update_percentage()

        Checkbutton(
            task_frame,
            variable = done_var,
            command = mark_done
        ).pack(side = LEFT, padx = 5)

        Label(
            task_frame,
            text=f"{i+1}. Task: {task['task']}\n"
                f"    Category: {task['category']}\n"
                f"    Due Date: {task['date']}\n"
                f"    Time: {task['time']}\n"
                f"    Priority: {task['priority']}",
            justify="left",
            anchor="w"
        ).pack(side=LEFT)

def search_tasks():
    keyword = search_entry.get().lower().strip()

    if keyword == "":
        refresh_tasks()
        return
    
    for widget in task_container.winfo_children():
        widget.destroy()
    
    result_number = 1

    for task in tasks:

        if(keyword in task["task"].lower() or
            keyword in task["category"].lower()):
            
            result_frame = Frame(task_container, relief = "solid", bd = 1)
            result_frame.pack(fill = X, padx = 10, pady = 5)

            Label(result_frame,
                text = f"{result_number}. Task: {task['task']}\n"
                    f"      Category: {task['category']}\n"
                    f"      Due Date: {task['date']}\n"
                    f"      Time: {task['time']}\n"
                    f"      Priority: {task['priority']}",
                justify = "left",
                anchor = "w"
            ).pack(side = LEFT)

            result_number += 1

