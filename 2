def update_percentage():
    global percentage

    if len(tasks) == 0:
        percentage = 0
    else: 
        completed = 0

        for task in tasks:
            if task["done"]:
                completed += 1
        percentage = int((completed/len(tasks))*100)
    percentage_label.config(
        text = f"Completition Percentage: {percentage} %"
    )

#popups
add_window = None

def open_add_task():
    global add_window

    if add_window is not None and add_window.winfo_exists():
        add_window.lift()
        add_window.focus_force()
        return

    add_window = Toplevel(root)
    add_window.title("Add Task")
    add_window.geometry("400x600")

    def close_add_window():
        global add_window
        add_window.destroy()
        add_window = None
    
    add_window.protocol("WM_DELETE_WINDOW", close_add_window)

    Label(add_window,
        text = "Task Name: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)
    
    task_entry = Entry(add_window)
    task_entry.pack()

    Label(add_window,
        text = "Category: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    category_entry = Entry(add_window)
    category_entry.pack()

    Label(add_window,
        text = "Due Date: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    date_entry = Entry(add_window)
    date_entry.pack()

    Label(add_window,
        text = "Time: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    time_entry = Entry(add_window)
    time_entry.pack()

    Label(add_window,
        text = "Priority: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    priority_var = StringVar(value = "Medium")

    Radiobutton(
        add_window,
        text = "High",
        variable = priority_var,
        value = "High"
    ).pack()

    Radiobutton(
        add_window,
        text = "Medium",
        variable = priority_var,
        value = "Medium",
    ).pack()

    Radiobutton(
        add_window,
        text = "Low",
        variable = priority_var,
        value = "Low"
    ).pack()
    
    def add_task():
        task = task_entry.get()
        category = category_entry.get()
        date = date_entry.get()
        time = time_entry.get()
        priority = priority_var.get()

        try:
            datetime.strptime(date, "%m-%d-%Y")
        except ValueError:
            messagebox.showerror(
                "Invalid Date",
                "PLease enter date as MM-DD-YYYY"
            )
            return
        
        try:
            datetime.strptime(time, "%H:%M")
        except ValueError:
            messagebox.showerror(
                "Invalid Time",
                "Please enter time as HH:MM"
            )
            return
        
        task_datetime = datetime.strptime(
            f"{date} {time}",
            "%m-%d-%Y %H:%M"
        )

        if task_datetime <= datetime.now():
            messagebox.showerror(
                "Expired Task",
                "This date and time have already passed."
            )
            return
        
        tasks.append({
                "task": task,
                "category": category,
                "date": date,
                "time": time,
                "priority": priority,
                "done": False,
            })

        refresh_tasks()
        update_percentage()

        close_add_window()

    Button(
        add_window,
        text = "Add Task",
        command = add_task
    ).pack(pady=10)

