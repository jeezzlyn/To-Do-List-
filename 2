#Functions
delete_mode = False

def delete_task(task_data):
    task_data["frame"].destroy()

    if task_data in tasks:
        tasks.remove(task_data)

    refresh_tasks()
    update_percentage()

def toggle_delete():
    global delete_mode

    delete_mode = not delete_mode

    for task in tasks:
        if delete_mode:
            task["delete_button"].pack(side = LEFT, padx = 5)

#Bottom Buttons
def go_back():
    global streak

    if len(tasks) > 0:
        completed = 0

        for task in tasks:
            if task["done"]:
                completed += 1
        if completed == len(tasks):
            streak += 1
    streak_label.config(text = f"Streak: {streak} days")

    update_percentage()

    main_frame.pack_forget()
    welcome_frame.pack(fill = BOTH, expand = True)

def load_task():
    global tasks

    try:
        wb = load_workbook("tasks.xlsx")
        ws = wb.active

        tasks.clear()

        # Clear existing task widgets
        for widget in task_container.winfo_children():
            widget.destroy()

        for row in ws.iter_rows(min_row = 2, values_only=True):

            task = {
                "task": row[0],
                "category": row[1],
                "date": row[2],
                "time": row[3],
                "priority": row[4],
                "done": row[5]
            }

            tasks.append(task)

            task_number = len(tasks)
            task_index = len(tasks) - 1

            task_frame = Frame(task_container, relief="solid", bd=1)
            task_frame.pack(fill = X, padx = 10, pady = 5)
            
            tasks[task_index]["frame"] = task_frame

            delete_button = Button(
                    task_frame,
                    text = "❌",
                    command = lambda t=task: delete_task(t)
            )

            tasks[task_index]["delete_button"] = delete_button

            done_var = BooleanVar(value =  task["done"])

            def mark_done (index = task_index, var = done_var):
                tasks[index]["done"] = var.get()
                update_percentage()

            Checkbutton(
                task_frame,
                variable = done_var,
                command = mark_done
            ).pack(side = LEFT, padx = 5)

            Label(
                task_frame,
                text = f"{task_number}. Task: {task['task']}\n"
                    f"      Category: {task['category']}\n"
                    f"      Due Date: {task['date']}\n"
                    f"      Time: {task['time']}\n"
                    f"      Priority: {task['priority']}",
                justify = "left",
                anchor = "w"
            ).pack(side=LEFT)

        update_percentage()

    except FileNotFoundError:
        print("No saved file found.")

def save_task():
    wb = Workbook()
    ws = wb.active

    ws.append([
        "Task",
        "Category",
        "Date",
        "Time",
        "Priority",
        "Done"
    ])

    for task in tasks:
        ws.append([
            task["task"],
            task["category"],
            task["date"],
            task["time"],
            task["priority"],
            task["done"]
        ])

    wb.save("tasks.xlsx")

