#Characters
buddy_frame = Frame(
    list_frame,
    bd = 0
)

buddy_frame.place(
    relx = 0.67,
    rely = 0.45,
    anchor = "center"
)

motivation = [
    "You got this! 💪",
    "Small steps every day 🌱",
    "Keep going! ⭐",
    "Don't forget to drink water!🥤"
]
motivation_job = None

def show_motivation():
    global motivation_job

    completed = sum(task["done"] for task in tasks)
    total = len(tasks)

    if 0 < completed < total:
        speech_label.config(text=random.choice(motivation))

    motivation_job = None

speech_label = Label(
    buddy_frame,
    text = "Let's go! 🌱",
    font = ("Helvetica",12),
    padx = 15,
    pady = 10,
    wraplength = 180,
    relief = "ridge",
    bd = 2
)
speech_label.pack(pady = (0,10))

buddy_label = Label(
    buddy_frame,
    image = char_photo,
)
buddy_label.pack()

def update_buddy():
    global motivation_job

    idle_seconds = (datetime.now() - last_activity).total_seconds()

    if idle_seconds > 60:
        buddy_label.config(image=sleep_photo)
        speech_label.config(text="Zzz... 😴")
        return
    
    completed = sum(task["done"] for task in tasks)
    total = len(tasks)

    if dark_mode:
        speech_label.config(
            bg = "#3A3A3A",
            fg = "#FFFFFF"
        )
    else:
        speech_label.config(
            bg = "#FFF8D6",
            fg = "#000000"
        )

    if total == 0:
        if motivation_job is not None:
            root.after_cancel(motivation_job)
            motivation_job = None

        buddy_label.config(image = char_photo)
        speech_label.config(text = "Let's plan today's tasks! 🌱")

    elif completed == 0:
        if motivation_job is not None:
            root.after_cancel(motivation_job)
            motivation_job = None

        buddy_label.config(image = bello_photo)
        speech_label.config(text = "Ready to start? 💪")

    elif completed < total:
        buddy_label.config(image = happy_photo)

        if motivation_job is None:
            speech_label.config(
                text=f"Only {total-completed} task(s) left! ⭐"
            )
            motivation_job = root.after(4000, show_motivation)

    else:
        if motivation_job is not None:
            root.after_cancel(motivation_job)
            motivation_job = None

        buddy_label.config(image = happy_photo)
        speech_label.config(text = "YOU DID IT!! 🎉")

last_activity = datetime.now()

def user_activity(event = None):
    global last_activity

    last_activity = datetime.now()

    update_buddy()

root.bind_all("<Button-1>", user_activity)
root.bind_all("<Key>", user_activity)

def check_idle():

    update_buddy()

    root.after(10000, check_idle)

floating = True

def float_buddy():
    global floating

    if floating:
        buddy_frame.place_configure(rely = 0.45)
    else:
        buddy_frame.place_configure(rely = 0.44)

    floating = not floating

    root.after(500, float_buddy)

float_buddy()

completed = 0

for task in tasks:
    if task["done"]:
        completed += 1

update_clock()

load_task()       
update_streak()

check_idle()
check_reminders()

root.mainloop()