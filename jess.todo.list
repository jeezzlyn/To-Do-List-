#Mouse Tasks
def mouse_scroll(event):
    first, last = canvas.yview()

    if event.delta > 0 and first <= 0:
        return

    canvas.yview_scroll(int(-1 * (event.delta / 120)), "units")

canvas.bind("<Enter>", lambda e: canvas.bind_all("<MouseWheel>", mouse_scroll))
canvas.bind("<Leave>", lambda e: canvas.unbind_all("<MouseWheel>"))

task_container.bind(
    "<Configure>",
    lambda e: canvas.configure(
        scrollregion = canvas.bbox("all")
    )
)

canvas_window = canvas.create_window((0, 0), window = task_container, anchor = "nw")

def resize_canvas(event):
    canvas.itemconfig(
        canvas_window,
        width = canvas.winfo_width()
    )

canvas.bind("<Configure>", resize_canvas)

canvas.yview_moveto(0)
canvas.configure(yscrollcommand = scrollbar.set)

canvas.pack(side = LEFT, fill = BOTH, expand = True)
scrollbar.pack(side = RIGHT, fill = Y)

root.after(100, lambda: resize_canvas(None))

#Functions
delete_mode = False

def delete_task(task_data):
    if task_data in tasks:
        tasks.remove(task_data)

    save_task()
    refresh_tasks()
    update_percentage()
    update_upcoming()
    update_overdue()
    update_buddy()

def toggle_delete():
    global delete_mode

    delete_mode = not delete_mode

    for task in tasks:
        if delete_mode:
            task["delete_button"].pack(side = RIGHT, padx = 5)
        else:
            task["delete_button"].pack_forget()

def go_back():

    update_streak()

    update_percentage()

    main_frame.pack_forget()
    welcome_frame.pack(fill = BOTH, expand = True)

def load_task():
    global tasks, streak, last_streak_date

    try:
        wb = load_workbook("tasks.xlsx")

        if "Tasks" in wb.sheetnames:
            ws = wb["Tasks"]
        else:
            ws = wb.active        

        tasks.clear()

        for widget in task_container.winfo_children():
            widget.destroy()

        for row in ws.iter_rows(min_row=2, values_only=True):
            task = {
                "task": row[0],
                "category": row[1],
                "date": row[2],
                "time": row[3],
                "priority": row[4],
                "done": row[5],
                "completed_date": row[6] if len(row) > 6 and row[6] else ""
            }

            tasks.append(task)

        if "Stats" in wb.sheetnames:

            stats = wb["Stats"]

            streak = stats["B1"].value or 0

            saved_date = stats["B2"].value

            if saved_date:
                last_streak_date = datetime.strptime(
                    saved_date,
                    "%Y-%m-%d"
                ).date()
            else:
                last_streak_date = None

        update_streak()

        refresh_tasks()
        update_percentage()
        update_upcoming()
        update_overdue()
        update_buddy()
        update_daily_quote()

    except FileNotFoundError:
        print("No saved file found.")

def save_task():
    wb = Workbook()

    ws = wb.active
    ws.title = "Tasks"      

    ws.append([
        "Task",
        "Category",
        "Date",
        "Time",
        "Priority",
        "Done",
        "COmpleted Date"
    ])

    for task in tasks:
        ws.append([
            task["task"],
            task["category"],
            task["date"],
            task["time"],
            task["priority"],
            task["done"],
            task["completed_date"]
        ])

    stats = wb.create_sheet("Stats")

    stats["A1"] = "Streak"
    stats["B1"] = streak

    stats["A2"] = "Last Date"

    if last_streak_date:
        stats["B2"] = last_streak_date.strftime("%Y-%m-%d")
    else:
        stats["B2"] = ""

    wb.save("tasks.xlsx")
    print("Saved successfully!")

#popups
add_window = None

def open_add_task():
    global add_window

    if add_window is not None and add_window.winfo_exists():
        add_window.lift()
        add_window.focus_force()
        return

    add_window = Toplevel(root)
    add_window.title("Add Task")
    add_window.geometry("400x600")

    def close_add_window():
        global add_window
        add_window.destroy()
        add_window = None
    
    add_window.protocol("WM_DELETE_WINDOW", close_add_window)

    Label(add_window,
        text = "Task Name: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)
    
    task_entry = Entry(add_window)
    task_entry.pack()

    Label(add_window,
        text = "Category: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    category_entry = Entry(add_window)
    category_entry.pack()

    Label(add_window,
        text = "Due Date (MM-DD-YYYY): ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    date_entry = Entry(add_window)
    date_entry.pack()

    Label(add_window,
        text = "Time (HH:MM): ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    time_entry = Entry(add_window)
    time_entry.pack()

    Label(add_window,
        text = "Priority: ",
        font = ("Helvetica", 14)
    ).pack(pady = 10)

    priority_var = StringVar(value = "Medium")

    Radiobutton(
        add_window,
        text = "High",
        variable = priority_var,
        value = "High",
        cursor = "hand2"
    ).pack()

    Radiobutton(
        add_window,
        text = "Medium",
        variable = priority_var,
        value = "Medium",
        cursor = "hand2"
    ).pack()

    Radiobutton(
        add_window,
        text = "Low",
        variable = priority_var,
        value = "Low",
        cursor = "hand2"
    ).pack()
    
    def add_task():
        task = task_entry.get()
        category = category_entry.get()
        date = date_entry.get()
        time = time_entry.get()
        priority = priority_var.get()

        try:
            datetime.strptime(date, "%m-%d-%Y")
        except ValueError:
            messagebox.showerror(
                "Invalid Date",
                "PLease enter date as MM-DD-YYYY"
            )
            return
        
        try:
            datetime.strptime(time, "%H:%M")
        except ValueError:
            messagebox.showerror(
                "Invalid Time",
                "Please enter time as HH:MM"
            )
            return
        
        task_datetime = datetime.strptime(
            f"{date} {time}",
            "%m-%d-%Y %H:%M"
        )

        if task_datetime <= datetime.now():
            messagebox.showerror(
                "Expired Task",
                "This date and time have already passed."
            )
            return
        
        tasks.append({
                "task": task,
                "category": category,
                "date": date,
                "time": time,
                "priority": priority,
                "done": False,
                "completed_date": ""
            })

        save_task()
        refresh_tasks()
        update_percentage()
        update_upcoming()
        update_overdue()
        update_buddy()

        close_add_window()

    Button(
        add_window,
        text = "Add Task",
        command = add_task,
        cursor = "hand2"
    ).pack(pady=10)

